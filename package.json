{
  "name": "booknest-frontend-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "config": "node scripts/set-env.js",
    "start": "npm run config && ng serve",
    "build": "npm run config && ng build",
    "watch": "npm run config && ng build --watch --configuration development",
    "test": "ng test",
    "test:ui": "ng test --ui",
    "test:coverage": "ng test --coverage --watch=false --coverage-reporters lcov",
    "sonar": "sonar-scanner"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/animations": "^21.2.12",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@angular/router": "^21.2.12",
    "chart.js": "^4.5.1",
    "ng2-charts": "^10.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.5.0",
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "dotenv": "^17.4.2",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "sonarqube-scanner": "^4.3.6",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
